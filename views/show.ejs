<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post details</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>post details</h1>
    <div class="post">
        <h2 class="id">id: <%=post.id%></h2>
        <h2 class="user">user: @<%=post.username%></h2>
        <h2 class="content">content: <%=post.content%></h2>
    </div>
</body>
</html>